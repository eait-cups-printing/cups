diff --git a/scheduler/auth.c b/scheduler/auth.c
index 7f6c3f6d2..b0b1162bb 100644
--- a/scheduler/auth.c
+++ b/scheduler/auth.c
@@ -1557,7 +1557,6 @@ cupsdIsAuthorized(cupsd_client_t *con,	/* I - Connection */
 		  "Negotiate"
 		};
 
-
   cupsdLogMessage(CUPSD_LOG_DEBUG2, "cupsdIsAuthorized: con->uri=\"%s\", con->best=%p(%s)", con->uri, con->best, con->best ? con->best->location ? con->best->location : "(null)" : "");
   if (owner)
     cupsdLogMessage(CUPSD_LOG_DEBUG2, "cupsdIsAuthorized: owner=\"%s\"", owner);
@@ -1657,6 +1656,81 @@ cupsdIsAuthorized(cupsd_client_t *con,	/* I - Connection */
       (type == CUPSD_AUTH_NONE && cupsArrayCount(best->names) == 0))
     return (HTTP_OK);
 
+
+ /*
+  * Custom authorization...
+  */
+  static char *cups_check_custom_auth_command = "/usr/local/libexec/cups_check_custom_auth";
+  if (access(cups_check_custom_auth_command, X_OK) == 0 && best->level == CUPSD_AUTH_USER && !con->is_browser)
+  {
+    char *argv[4],           /* Command-line arguments */
+         *envp[MAX_ENV];     /* Environment */
+    int	  temppid;           /* Process ID for custom auth processes */
+    int   outfds[2];         /* Pipe file descriptors for stdout */
+    int   errfds[2];         /* Pipe file descriptors for stderr */
+
+    /* argv[n] corresponds to custom authorization process's argv[n + 1] */
+    argv[0] = con->username;
+    argv[1] = owner ? (char *)owner : "";
+    argv[2] = (char *)ippOpString(best->op); /* IPP operation */
+    argv[3] = (char *)httpGetHostname(con->http, NULL, 0); /* client hostname or IP address */
+    argv[4] = httpAddrFamily(hostaddr) == AF_INET ? "4" : "6"; /* IPv4 or IPv6 */
+    argv[5] = con->uri;
+    argv[6] = con->options ? con->options : "";
+    argv[7] = NULL;
+
+    cupsdLoadEnv(envp, (int)(sizeof(envp) / sizeof(envp[0])));
+
+    if (cupsdOpenPipe(outfds) || cupsdOpenPipe(errfds))
+    {
+      cupsdLogMessage(CUPSD_LOG_ERROR, "Unable to create pipe for %s - %s",
+                      cups_check_custom_auth_command, strerror(errno));
+      return (HTTP_UNAUTHORIZED);
+    }
+
+    if(cupsdStartProcess(cups_check_custom_auth_command, argv, envp, -1, outfds[1], errfds[1], -1, -1, 0, DefaultProfile, NULL, &temppid) < 0)
+    {
+      /*
+       * Error - can't fork!
+       */
+
+      cupsdLogMessage(CUPSD_LOG_ERROR, "Unable to fork %s - %s",
+                      cups_check_custom_auth_command, strerror(errno));
+
+      cupsdClosePipe(outfds);
+      cupsdClosePipe(errfds);
+      return (HTTP_UNAUTHORIZED);
+    }
+    else
+    {
+      /*
+       * Fork successful ...
+       */
+      char  buffer[2048];
+
+      cupsdLogMessage(CUPSD_LOG_DEBUG, "Started %s- PID = %d", cups_check_custom_auth_command, temppid);
+
+      close(outfds[1]);
+      close(errfds[1]);
+
+      if (read(errfds[0], buffer, sizeof(buffer)) > 0) {
+        cupsdLogMessage(CUPSD_LOG_ERROR, "%s", buffer);
+      }
+
+      if (read(outfds[0], username, sizeof(username)) > 0) {
+      cupsdLogMessage(CUPSD_LOG_DEBUG, "cupsdIsAuthorized using custom authorization: username=\"%s\"",
+	              username);
+      }
+
+      cupsdClosePipe(outfds);
+      cupsdClosePipe(errfds);
+
+      if (con->username[0]) {
+        return (HTTP_OK);
+      }
+    }
+  }
+
   if (!con->username[0] && type == CUPSD_AUTH_NONE &&
       best->limit == CUPSD_AUTH_LIMIT_IPP)
   {
